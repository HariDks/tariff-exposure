# RStudio
.Rproj.user/
.Rhistory
.RData
.Ruserdata

# renv — keep lock file, ignore the local library
renv/library/
renv/local/
renv/cellar/
renv/lock.lock
renv/python/
renv/staging/

# Raw data: ignore everything (large, re-downloadable, may have license terms
# from BLS / PIIE / Census that we shouldn't blanket re-redistribute).
# Keep .gitkeep so the folder exists.
data/raw/**
!data/raw/.gitkeep

# Processed data is regenerated by R scripts
data/processed/**
!data/processed/.gitkeep

# Output: keep figures + tables in git (lightweight, helps readers viewing
# the report on GitHub without rendering it themselves). Skip the heavy
# Leaflet HTML which is 52 MB.
output/figures/tariff_exposure_interactive.html

# Quarto build artifacts
/.quarto/
report_files/
report_cache/

# API keys live in .Renviron — never commit
.Renviron

# macOS
.DS_Store
